{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information, matching auth.uid",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "subscriptions": {
          "type": "object",
          "description": "Active VIP subscriptions map, e.g. { 'vip_cs_today': true }"
        }
      },
      "required": ["uid", "username", "email", "role", "createdAt"]
    },
    "Category": {
      "title": "Tips Category",
      "description": "Contains matches and ticket information for a specific tip category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "iconName": { "type": "string" },
        "tickets": {
          "type": "array",
          "description": "List of active tickets for this category"
        }
      },
      "required": ["id", "title", "iconName", "tickets"]
    },
    "Proof": {
      "title": "Payment Proof",
      "description": "Payment proof screenshot submitted by user for VIP activation",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string" },
        "categoryId": { "type": "string" },
        "screenshot": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string" },
        "amount": { "type": "string" }
      },
      "required": ["id", "userId", "username", "email", "categoryId", "screenshot", "status", "createdAt"]
    },
    "Agent": {
      "title": "Support Agent",
      "description": "Agent profiles for professional customer support chat",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "imageUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["available", "busy", "offline"] }
      },
      "required": ["id", "name", "role", "imageUrl", "status"]
    },
    "TypingState": {
      "title": "Typing State",
      "description": "Real-time typing status between users and support agents",
      "type": "object",
      "properties": {
        "userTyping": { "type": "boolean" },
        "userLastTyped": { "type": "integer" },
        "adminTyping": { "type": "boolean" },
        "adminLastTyped": { "type": "integer" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Match tip categories containing matches data"
    },
    "/proofs/{proofId}": {
      "schema": "Proof",
      "description": "Payment proof submissions"
    },
    "/agents/{agentId}": {
      "schema": "Agent",
      "description": "Support agent profiles"
    },
    "/typing_states/{userId}": {
      "schema": "TypingState",
      "description": "Real-time typing indicator states"
    }
  }
}
