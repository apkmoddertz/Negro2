rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global safety net - default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Reusable, hardened helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Hardened admin check:
    // Ensure email is checked case-insensitively for safety.
    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.email.matches('(?i)jilalamasanja1998@gmail.com');
    }

    // Path ID safety pattern
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 2. Users collection rules
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin(); // Avoid blanket reads on private user info
      
      // Allow users to register their initial profile
      allow create: if isSignedIn() && 
                    isValidId(userId) &&
                    request.auth.uid == userId && 
                    (
                      request.resource.data.role == "user" ||
                      (request.resource.data.role == "admin" && isAdmin())
                    ) &&
                    request.resource.data.email == request.auth.token.email;

      // Allow users to edit their username, but prevent self-elevation of roles or subscriptions
      allow update: if isAdmin() ||
                    (
                      isSignedIn() && 
                      isValidId(userId) &&
                      request.auth.uid == userId && 
                      request.resource.data.role == resource.data.role &&
                      (request.resource.data.get('subscriptions', null) == resource.data.get('subscriptions', null))
                    );

      allow delete: if isAdmin();
    }

    // 3. Categories and Matches collection rules
    match /categories/{categoryId} {
      // Anyone can read matches and tip categories
      allow read: if true;
      
      // Only the verified admin can modify matches data
      allow create, update, delete: if isAdmin();
    }

    // 4. Proofs collection rules
    match /proofs/{proofId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && 
                    isValidId(proofId) &&
                    request.resource.data.userId == request.auth.uid &&
                    request.resource.data.status == "pending";
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
